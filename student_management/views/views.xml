<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <!--    List view of student.student model(Start)-->

    <record id="student_student_view_list" model="ir.ui.view">
        <field name="name">Student student list view</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="dob"/>
                <field name="gender" widget="badge" decoration-success="gender == 'male'"
                       decoration-warning="gender == 'female'" decoration-danger="gender == 'other'"/>
                <field name="class_id"/>
            </list>
        </field>
    </record>

    <!--    List view of student.student model(End)-->


    <!--    Form view of student.student model(Start)-->

    <record id="student_student_view_form" model="ir.ui.view">
        <field name="name">Student student form view</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button type="object" string="Click" class="oe_highlight" name="print_something"/>
                    <button type="object" string="Show rainbow" class="oe_highlight" name="show_rainbow"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <field name="name"/>
                        <field name="student_id"/>
                        <field name="dob"/>
                        <field name="gender"/>
                        <field name="class_id"/>
                        <field name="subject_ids" widget="many2many_tags"/>
                        <notebook>
                            <page string="Contact">
                                <group>
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="address"/>
                                </group>
                            </page>
                            <page string="Guardian_info">
                                <group>
                                    <field name="guardian_name"/>
                                    <field name="guardian_phone"/>
                                    <field name="admission_date"/>
                                </group>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Form view of student.student model(End)-->


    <!--    Search view of student.student model(End)-->

    <record id="student_student_view_search" model="ir.ui.view">
        <field name="name">Student student search view</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="student_id"/>
                <filter name="filter_by_male" string="Male" domain="[('gender', '=', 'male')]"/>
                <filter name="filter_by_female" string="Female" domain="[('gender', '=', 'female')]"/>
                <filter name="filter_by_other" string="Other" domain="[('gender', '=', 'other')]"/>
                <filter name="group_by_gender" string="Gender" context="{'group_by' : 'gender'}"/>
            </search>
        </field>
    </record>

    <!--    Search view of student.student model(End)-->


    <!--    Kanban view of student.student model(Start)-->
    <record id="student_student_view_kanban" model="ir.ui.view">
        <field name="name">Student student kanban view</field>
        <field name="model">student.student</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="gender"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('student.student', 'image', record.id.raw_value)"
                                alt="student image"/>
                            </div>

                            <div class="d-flex justify-content-between px-2">
                                <div>
                                    <strong>
                                        <field name="name"/>
                                    </strong>
                                    <br/>
                                    <field name="student_id"/>
                                    <br/>
                                    <field name="dob"/>
                                </div>

                                <div>
                                    <t t-if="record.gender.raw_value == 'male'">
                                        <p class="badge rounded-pill bg-success text-white">Male</p>
                                    </t>

                                    <t t-if="record.gender.raw_value == 'female'">
                                        <p class="badge rounded-pill bg-warning text-white">Female</p>
                                    </t>

                                    <t t-if="record.gender.raw_value == 'other'">
                                        <p class="badge rounded-pill bg-danger text-white">Other</p>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--    Kanban view of student.student model(End)-->


    <!--    Action of student.student model(Start)-->

    <record id="student_student_action" model="ir.actions.act_window">
        <field name="name">Student</field>
        <field name="res_model">student.student</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <!--    Action of student.student model(End)-->

    <!--    List view of student.class model (Start)-->
    <record id="student_class_view_list" model="ir.ui.view">
        <field name="name">Student class list view</field>
        <field name="model">student.class</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <!--    List view of student.class model (End)-->

    <!--    Form view of student.class model (Start)-->
    <record id="student_class_view_form" model="ir.ui.view">
        <field name="name">Student class form view</field>
        <field name="model">student.class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Form view of student.class model (End)-->


    <!--    Action of student.class model(Start)-->
    <record id="student_class_action" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">student.class</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--    Action of student.class model(End)-->

    <!--    List view of student.subject(Start)-->
    <record id="student_subject_view_list" model="ir.ui.view">
        <field name="name">Student subject list view</field>
        <field name="model">student.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>
    <!--    List view of student.subject(End)-->

    <!--    Form view of student.subject model (Start)-->
    <record id="student_subject_view_form" model="ir.ui.view">
        <field name="name">Student subject form view</field>
        <field name="model">student.subject</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Form view of student.subject model (End)-->

        <!--    Action of student.subject model(Start)-->
    <record id="student_subject_action" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">student.subject</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--    Action of student.subject model(End)-->
</odoo>